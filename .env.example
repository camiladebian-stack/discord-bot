# Discord Bot Token (required)
# From https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Client ID (required for slash commands)
# From https://discord.com/developers/applications
CLIENT_ID=your_client_id_here

# Guild ID for development (optional)
# Restricts slash commands to a single guild for instant updates
DEV_GUILD_ID=

# Bot configuration
# Name shown in status
BOT_NAME=MyBot
# Activity message
BOT_ACTIVITY=/help | v1.0.0
# Activity type: PLAYING, WATCHING, LISTENING, COMPETING
BOT_ACTIVITY_TYPE=PLAYING

# Logging
LOG_LEVEL=info
# Combined log file
LOG_FILE=logs/combined.log
# Error-only log file
LOG_ERROR_FILE=logs/error.log

# Database
# Path to SQLite database file
DB_PATH=data/bot.db

# API Keys (optional - uncomment if using)
# OPENROUTER_API_KEY=
# WEATHER_API_KEY=

# Cooldown defaults (seconds)
COOLDOWN_DEFAULT=3
COOLDOWN_MODERATION=5

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Anti-spam
ANTI_SPAM_THRESHOLD=5
ANTI_SPAM_WINDOW_MS=10000

# AI Provider (optional)
# Options: openrouter, gemini, groq
AI_PROVIDER=
# Maximum tokens per AI response
AI_MAX_TOKENS=1024

# Health check port (for monitoring services)
HEALTH_PORT=8080

# Owner Discord user ID (for owner-only commands)
OWNER_ID=
